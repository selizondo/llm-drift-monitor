# Required for LLM quality scoring (judge).
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Required for W&B live dashboard.
# Get key: https://wandb.ai/settings
WANDB_API_KEY=

# Optional: W&B project name (defaults to "llm-drift-monitor")
# WANDB_PROJECT=llm-drift-monitor

# Run without W&B or quality scoring (drift detection only):
#   python run_monitor.py --no-quality --no-wandb
